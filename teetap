#!/bin/sh
# teetap — a detachable, tee-based local log tap.
# POSIX sh only; runtime deps: sh, tee, ln, mkdir, git, coreutils.
set -u

TEETAP_VERSION="0.1.0"
TEETAP_ROOT="${TEETAP_DIR:-$HOME/.local/state/teetap}"

project_dir() {
    top=$(git rev-parse --show-toplevel 2>/dev/null) || top=$PWD
    base=$(basename "$top")
    hash=$(printf '%s' "$top" | cksum | awk '{printf "%x", $1}')
    printf '%s/%s-%s\n' "$TEETAP_ROOT" "$base" "$hash"
}

cmd_path() {
    project_dir
}

# The dir key hashes the source path one-way; the breadcrumb preserves the
# mapping so `list` can show where each project lives. Dotfile: invisible
# to the "$dir"/* globs in status/off, and deliberately survives `off`.
ensure_project_dir() {
    dir=$(project_dir)
    mkdir -p "$dir"
    if [ ! -f "$dir/.teetap-project" ]; then
        top=$(git rev-parse --show-toplevel 2>/dev/null) || top=$PWD
        printf '%s\n' "$top" > "$dir/.teetap-project"
    fi
    printf '%s\n' "$dir"
}

now_iso() {
    date '+%Y-%m-%dT%H:%M:%S%z'
}

git_branch() {
    git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '-'
}

write_start_marker() { # file session_id name
    printf '===== teetap session %s start %s name=%s branch=%s cwd=%s pid=%s =====\n' \
        "$3" "$(now_iso)" "$2" "$(git_branch)" "$PWD" "$$" >> "$1"
}

write_end_marker() { # file session_id name exit_code
    printf '===== teetap session %s end %s name=%s exit=%s =====\n' \
        "$3" "$(now_iso)" "$2" "$4" >> "$1"
}

cmd_pipe() {
    name=${1:?usage: teetap pipe <name>}
    dir=$(ensure_project_dir)
    file="$dir/$name.log"
    sid="$(date +%Y%m%dT%H%M%S).$$"
    write_start_marker "$file" "$name" "$sid"
    tee -a "$file"
    write_end_marker "$file" "$name" "$sid" '-'
}

pidfile_for() { # dir name — dotfile: invisible to the "$dir"/* globs, like the breadcrumb
    printf '%s/.teetap-pid-%s\n' "$1" "$2"
}

live_pid_for() { # dir name — prints the pid iff the detached producer is alive
    _pid=$(cat "$(pidfile_for "$1" "$2")" 2>/dev/null) || return 1
    [ -n "$_pid" ] || return 1
    kill -0 "$_pid" 2>/dev/null || return 1
    printf '%s\n' "$_pid"
}

cmd_run() {
    lifecycle=append
    detach=0
    while :; do
        case "${1:-}" in
            --rotate) lifecycle=rotate; shift ;;
            --truncate) lifecycle=truncate; shift ;;
            --split) lifecycle=split; shift ;;
            -d|--detach) detach=1; shift ;;
            *) break ;;
        esac
    done
    name=${1:?usage: teetap run [-d] [--rotate|--truncate|--split] <name> -- <cmd> [args...]}
    shift
    [ "${1:-}" = '--' ] || { echo 'teetap run: expected -- before the command' >&2; exit 2; }
    shift
    [ $# -gt 0 ] || { echo 'teetap run: no command given' >&2; exit 2; }

    dir=$(ensure_project_dir)
    sid="$(date +%Y%m%dT%H%M%S).$$"
    file="$dir/$name.log"
    case "$lifecycle" in
        rotate) [ -f "$file" ] && mv "$file" "$dir/$name.prev.log" ;;
        truncate) : > "$file" ;;
        split) file="$dir/$name.$sid.log" ;;
    esac

    if [ "$detach" -eq 1 ]; then
        pidfile=$(pidfile_for "$dir" "$name")
        if oldpid=$(live_pid_for "$dir" "$name"); then
            printf 'teetap: %s is already running (pid %s) — teetap stop %s first\n' \
                "$name" "$oldpid" "$name" >&2
            exit 1
        fi
        rm -f "$pidfile"
        # The pidfile can't double as the started signal: a fast-exiting
        # producer is sealed (pidfile removed) before the parent ever polls.
        birth=$(mktemp)
        # The wrapper outlives this invocation: it forwards TERM to the
        # producer and writes the end marker, so marker discipline holds
        # whether the producer exits, crashes, or is stopped.
        (
            write_start_marker "$file" "$name" "$sid"
            "$@" </dev/null >> "$file" 2>&1 &
            prod=$!
            printf '%s\n' "$prod" > "$pidfile"
            printf '%s\n' "$prod" > "$birth"
            trap 'kill -TERM "$prod" 2>/dev/null' TERM
            wait "$prod"; ec=$?
            while kill -0 "$prod" 2>/dev/null; do wait "$prod"; ec=$?; done
            write_end_marker "$file" "$name" "$sid" "$ec"
            rm -f "$pidfile"
        ) </dev/null >/dev/null 2>&1 &
        i=0
        while [ ! -s "$birth" ] && [ "$i" -lt 50 ]; do sleep 0.1; i=$((i + 1)); done
        pid=$(cat "$birth" 2>/dev/null) || true
        rm -f "$birth"
        [ -n "${pid:-}" ] || { printf 'teetap run -d: %s failed to start\n' "$name" >&2; exit 1; }
        printf '%s started (pid %s) -> %s\n' "$name" "$pid" "$file"
        exit 0
    fi

    # A pipe hides the producer's exit status in POSIX sh; smuggle it out via a file.
    ec_file=$(mktemp)
    write_start_marker "$file" "$name" "$sid"
    { "$@" 2>&1; echo $? > "$ec_file"; } | tee -a "$file"
    ec=$(cat "$ec_file")
    rm -f "$ec_file"
    write_end_marker "$file" "$name" "$sid" "$ec"
    exit "$ec"
}

cmd_stop() {
    grace=10
    if [ "${1:-}" = '-t' ]; then
        grace=${2:?usage: teetap stop [-t <seconds>] <name>}
        shift 2
    fi
    name=${1:?usage: teetap stop [-t <seconds>] <name>}
    dir=$(project_dir)
    pidfile=$(pidfile_for "$dir" "$name")
    if ! pid=$(live_pid_for "$dir" "$name"); then
        rm -f "$pidfile"
        printf 'teetap: %s is not running\n' "$name" >&2
        exit 0
    fi
    kill -TERM "$pid" 2>/dev/null
    waited=0
    while kill -0 "$pid" 2>/dev/null && [ "$waited" -lt "$grace" ]; do
        sleep 1
        waited=$((waited + 1))
    done
    kill -0 "$pid" 2>/dev/null && kill -KILL "$pid" 2>/dev/null
    # The wrapper seals the session (end marker, pidfile removal) just after
    # the producer dies; give it a moment so stop returns a consistent state.
    i=0
    while [ -f "$pidfile" ] && [ "$i" -lt 50 ]; do sleep 0.1; i=$((i + 1)); done
    printf '%s stopped\n' "$name"
}

cmd_pm2() {
    [ "${1:-}" = 'link' ] || { echo 'usage: teetap pm2 link [name-filter...]' >&2; exit 2; }
    shift
    src="${TEETAP_PM2_LOGS:-$HOME/.pm2/logs}"
    [ -d "$src" ] || { printf 'teetap: pm2 log directory not found: %s\n' "$src" >&2; exit 1; }
    dir=$(ensure_project_dir)

    for log in "$src"/*.log; do
        [ -f "$log" ] || continue
        base=$(basename "$log")
        if [ $# -gt 0 ]; then
            matched=0
            for f in "$@"; do
                case "$base" in *"$f"*) matched=1 ;; esac
            done
            [ "$matched" -eq 1 ] || continue
        fi
        ln -sf "$log" "$dir/pm2-$base"
    done

    for link in "$dir"/pm2-*; do
        [ -L "$link" ] || continue
        [ -e "$link" ] || rm -f "$link"
    done
}

mtime_of() { # BSD stat and GNU stat disagree on flags; try both.
    stat -f %m "$1" 2>/dev/null || stat -c %Y "$1" 2>/dev/null
}

cmd_status() {
    dir=$(project_dir)
    [ -d "$dir" ] || { printf 'teetap: nothing tapped here (no %s)\n' "$dir"; exit 0; }
    now=$(date +%s)
    printf 'NAME\tTYPE\tBYTES\tAGE_S\n'
    for entry in "$dir"/*; do
        [ -e "$entry" ] || [ -L "$entry" ] || continue
        name=$(basename "$entry" .log)
        if [ -L "$entry" ]; then
            type=link
        elif live_pid_for "$dir" "$name" >/dev/null; then
            type=run
        else
            type=tee
        fi
        if [ -e "$entry" ]; then
            size=$(wc -c < "$entry" | tr -d ' ')
            age=$(( now - $(mtime_of "$entry") ))
        else
            size='-'; age='-'
        fi
        printf '%s\t%s\t%s\t%s\n' "$name" "$type" "$size" "$age"
    done
}

cmd_list() {
    [ -d "$TEETAP_ROOT" ] || { printf 'teetap: nothing tapped anywhere (no %s)\n' "$TEETAP_ROOT"; exit 0; }
    now=$(date +%s)
    printf 'PROJECT\tPATH\tSOURCES\tAGE_S\n'
    for dir in "$TEETAP_ROOT"/*; do
        [ -d "$dir" ] || continue
        project=$(basename "$dir")
        path='-'
        [ -f "$dir/.teetap-project" ] && path=$(cat "$dir/.teetap-project")
        sources=0
        newest=0
        for entry in "$dir"/*; do
            [ -e "$entry" ] || [ -L "$entry" ] || continue
            sources=$((sources + 1))
            [ -e "$entry" ] || continue
            mt=$(mtime_of "$entry")
            [ "$mt" -gt "$newest" ] && newest=$mt
        done
        if [ "$newest" -gt 0 ]; then age=$((now - newest)); skey=$age; else age='-'; skey=99999999; fi
        # Sort key first so active projects rise to the top, then strip it.
        printf '%s\t%s\t%s\t%s\t%s\n' "$skey" "$project" "$path" "$sources" "$age"
    done | sort -n | cut -f2-
}

# A file written within the last N seconds is treated as a live capture.
TEETAP_LIVE_WINDOW=10

cmd_off() {
    force=0
    [ "${1:-}" = '--force' ] && force=1
    dir=$(project_dir)
    [ -d "$dir" ] || exit 0
    now=$(date +%s)
    for entry in "$dir"/*; do
        [ -e "$entry" ] || [ -L "$entry" ] || continue
        if [ -L "$entry" ]; then
            rm -f "$entry"
            continue
        fi
        name=$(basename "$entry" .log)
        # A tap teetap itself started outranks --force: stop ends processes,
        # off only cleans files.
        if pid=$(live_pid_for "$dir" "$name"); then
            printf 'teetap: %s is running (pid %s) — teetap stop %s first\n' \
                "$name" "$pid" "$name" >&2
            continue
        fi
        age=$(( now - $(mtime_of "$entry") ))
        if [ "$age" -lt "$TEETAP_LIVE_WINDOW" ] && [ "$force" -eq 0 ]; then
            printf 'teetap: %s looks live (written %ss ago) — stop the process or pass --force\n' \
                "$(basename "$entry")" "$age" >&2
            continue
        fi
        rm -f "$entry"
    done
}

script_dir() {
    cd "$(dirname "$0")" && pwd
}

cmd_skill() {
    [ "${1:-}" = 'install' ] || { echo 'usage: teetap skill install [--allow-fetch]' >&2; exit 2; }
    shift
    fetch=0
    [ "${1:-}" = '--allow-fetch' ] && fetch=1
    dest="${TEETAP_SKILLS_DIR:-$HOME/.claude/skills}/teetap"
    mkdir -p "$dest"

    bundled="$(script_dir)/skills/teetap"
    if [ "$fetch" -eq 1 ]; then
        # Full skill structure from this script's own release — one tarball, no manifest.
        repo="${TEETAP_REPO:-weefaa/teetap}"
        url="https://github.com/$repo/archive/refs/tags/v$TEETAP_VERSION.tar.gz"
        tmp=$(mktemp -d)
        if curl -fsSL "$url" | tar -xz -C "$tmp" 2>/dev/null; then
            cp -R "$tmp"/*/skills/teetap/. "$dest"/
            rm -rf "$tmp"
        else
            rm -rf "$tmp"
            printf 'teetap: could not fetch skill from %s\n' "$url" >&2
            exit 1
        fi
    elif [ -f "$bundled/SKILL.md" ] && [ "$bundled" != "$dest" ]; then
        cp -R "$bundled"/. "$dest"/
    else
        write_embedded_skill "$dest/SKILL.md"
    fi
    printf 'teetap: skill installed to %s\n' "$dest"
}

# Offline fallback for standalone installs: SKILL.md only, version-locked to
# this binary. Must stay byte-identical to skills/teetap/SKILL.md (test-enforced).
write_embedded_skill() {
    cat > "$1" <<'SKILL_EOF'
---
name: teetap
description: Read the developer's local process logs (dev servers, PM2 workers, any piped stream) without owning the process. Use when debugging local behavior, when asked to "check the logs", "watch the server", "what happened when I...", or when you need runtime output you did not start yourself.
---

# teetap — read local process logs you don't own

The developer taps their processes with `teetap`; output lands in one
directory per project, outside the repo. You read it with tail/grep.

## Quick start

```sh
DIR=$(teetap path)     # this project's log directory (never derive it yourself)
teetap status          # NAME TYPE BYTES AGE_S — what's tapped, how fresh
tail -50 "$DIR"/dev.log
```

If `teetap status` shows nothing here, the logs may belong to a project
tapped from another directory — see "Choosing the project" below.

## Choosing the project

When this directory has no tap, consult the registry (never hunt the
filesystem outside teetap's own directory):

```sh
teetap list            # PROJECT  PATH  SOURCES  AGE_S — most recent first
```

- **0 rows** — the developer has not plugged in anywhere. Say so and stop.
- **1 row** — use it, stating the assumption: "Using PROJECT (PATH), the
  only tapped project."
- **2+ rows** — recommend one, then ASK the user; never silently pick.
  Rank candidates by: (1) path affinity — PATH is an ancestor, descendant,
  or sibling worktree of your cwd; (2) recency — smallest AGE_S;
  (3) name match against the user's words.

Then read from the chosen row's directory:

```sh
DIR="${TEETAP_DIR:-$HOME/.local/state/teetap}/PROJECT"
```

If `teetap list` fails as an unknown command, the installed binary
predates it — ask the developer to re-run the install one-liner instead
of improvising.

## Reading a log correctly

Files append across runs. Every run is bracketed by marker lines:

```
===== teetap session <id> start <time> name=dev branch=... cwd=... pid=... =====
===== teetap session <id> end <time> name=dev exit=0 =====
```

Scope your reading to the CURRENT run — everything after the last start
marker. Errors before it belong to a previous session:

```sh
tail -n "+$(grep -n 'teetap session .* start' "$DIR"/dev.log | tail -1 | cut -d: -f1)" "$DIR"/dev.log
```

An `exit=` value in the end marker is the wrapped command's exit code.

## Querying — treat the directory like a log store

Prefer `grep`/`sed`/`awk` over reading whole files: they are your query
language, and they compose into anything a hosted log store can answer.
Never dump a large log into context — query it down first.

```sh
grep -h "<request-id>" "$DIR"/*.log            # one identifier across ALL sources
grep -n  "ERROR\|error" "$DIR"/dev.log         # find errors, keep line numbers
sed -n '/13:18:00/,/13:18:30/p' "$DIR"/dev.log # time-range slice
```

Chain them like query stages: filter (`grep`) → slice (`sed -n 'X,Yp'`)
→ project/aggregate (`awk`, `sort | uniq -c | sort -rn`).

`EXAMPLES.md` next to this file (present when installed via
`npx skills add` or `teetap skill install --allow-fetch`) has the full
recipe collection and end-to-end walkthroughs; without it, compose the
three recipes above.

**What is running right now?** `teetap status` — `AGE_S` near 0 means
actively writing; large means idle or stopped. PM2 workers appear as
`pm2-<process>.log` symlinks — same directory, same queries.

**Previous run:** `<name>.prev.log` (exists only if the developer used
`--rotate`); split sessions are `<name>.<session-id>.log`.

## Advanced

Suggest taps to the developer (they run these, not you):

```sh
teetap run dev -- <any command>        # wrap: tees + records exit code
<producer> 2>&1 | teetap pipe <name>   # sink: tap any stream
teetap pm2 link                        # add PM2 logs to the aggregate
teetap off                             # detach when done
```

Full command reference: `man teetap` or `teetap --help`.
SKILL_EOF
}

usage() {
    cat <<'EOF'
usage: teetap <command>

capture:
  run [-d] [--rotate|--truncate|--split] <name> -- <cmd> [args...]
          wrap any command; tee output, record exit code (default: append)
          -d detaches: terminal back immediately, stop with `teetap stop`
  pipe <name>
          sink: tap any stream (producer | teetap pipe <name>)
  stop [-t <seconds>] <name>
          end a detached tap: TERM, grace (default 10s), then KILL

sources:
  pm2 link [name-filter...]
          symlink PM2 log files into this project's directory

inspect:
  path    print this project's log directory
  status  list sources: NAME TYPE BYTES AGE_S
  list    list all tapped projects: PROJECT PATH SOURCES AGE_S

manage:
  off [--force]
          remove symlinks and (non-live) capture files
  skill install [--allow-fetch]
          install the /teetap agent skill to ~/.claude/skills
          (recommended: npx skills add https://github.com/weefaa/teetap --skill teetap)
          offline by default; --allow-fetch pulls the full skill
          structure from this binary's release tag

environment:
  TEETAP_DIR         aggregate root (default ~/.local/state/teetap)
  TEETAP_PM2_LOGS    pm2 log directory (default ~/.pm2/logs)
  TEETAP_SKILLS_DIR  agent skills directory (default ~/.claude/skills)
EOF
}

case "${1:-}" in
    path) shift; cmd_path "$@" ;;
    pipe) shift; cmd_pipe "$@" ;;
    run) shift; cmd_run "$@" ;;
    stop) shift; cmd_stop "$@" ;;
    pm2) shift; cmd_pm2 "$@" ;;
    status) shift; cmd_status "$@" ;;
    list) shift; cmd_list "$@" ;;
    off) shift; cmd_off "$@" ;;
    skill) shift; cmd_skill "$@" ;;
    -h|--help|'') usage ;;
    --version) printf 'teetap %s\n' "$TEETAP_VERSION" ;;
    *) printf 'teetap: unknown command: %s\n' "$1" >&2; usage >&2; exit 1 ;;
esac
